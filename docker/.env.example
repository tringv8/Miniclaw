# Git source used during docker build
MINICLAW_REPO=https://github.com/tringv8/Miniclaw.git
MINICLAW_REF=main

# Optional launcher access token
MINICLAW_LAUNCHER_TOKEN=

# Telegram (optional)
TELEGRAM_BOT_TOKEN=

# Gmail / Google Calendar (optional, configured after startup)
# Bắt buộc khi chạy trong Docker — container không có system keyring
# GOG_KEYRING_BACKEND=file dùng file để lưu token thay vì GNOME/macOS Keychain
GOG_KEYRING_BACKEND=file
GOG_KEYRING_PASSWORD=password
